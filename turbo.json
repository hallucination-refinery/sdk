{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "test": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "test:coverage": {
      "outputs": ["coverage/**"],
      "cache": true
    },
    "lint": {
      "cache": true,
      "filter": ["./packages/**", "./apps/cryptiq-mindmap-demo/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}

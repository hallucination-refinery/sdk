{
  "allowedTools": [
    "Edit",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(rg:*)",
    "Bash(grep:*)",
    "Bash(find:*)",
    "Bash(cloc:*)",
    "Bash(git status:*)",
    "Bash(git diff:*)"
  ],
  "notes": "Conservative allowlist to enable read-only discovery; expand incrementally as needed.",
  "permissions": {
    "allow": [
      "Read(**/*)",
      "Grep(**/*)",
      "Glob(**/*)",
      "LS(**/*)",
      "Edit(**/*)",
      "MultiEdit(**/*)",
      "Write(**/*)",
      "Task",
      "TodoWrite",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(pnpm:*)",
      "Bash(npm run:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "WebFetch",
      "WebSearch",
      "Bash(curl:*)"
    ]
  },
  "hooks": {
    "PostToolUse": { "Bash": "pnpm -w -s format || npm run -s format || true" }
  }
}

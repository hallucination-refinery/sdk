{
  "name": "@refinery/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "tsc -b --clean tsconfig.build.json && tsc -b tsconfig.build.json",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "prepare": "husky install",
    "type-check": "tsc -b --clean tsconfig.build.json && tsc -b tsconfig.build.json",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "docs": "typedoc --plugin typedoc-plugin-markdown --entryPointStrategy Packages --entryPoints packages/* --skipErrorChecking --githubPages false --tsconfig tsconfig.build.json",
    "docs:watch": "typedoc --watch",
    "watch-smoke": "node scripts/watch-smoke.cjs",
    "smoke-check": "node scripts/watch-smoke.cjs --once",
    "smoke": "pnpm run smoke:draw3d || true && node -e \"console.log('smoke ok')\"",
    "smoke:draw3d": "pnpm --filter cryptiq-mindmap-demo run build && node -e \"require('fs').accessSync('apps/cryptiq-mindmap-demo/.next/server/app/draw3d/page.js')\"",
    "smoke:brain": "playwright test tests/brain.smoke.spec.ts --reporter=line",
    "vggt:readme": "node -e \"require('fs').createReadStream('tools/vggt-cli/README.md').pipe(process.stdout)\""
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "@playwright/test": "^1.45.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.17.15",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "clsx": "^2.1.1",
    "eslint": "^9.17.0",
    "immer": "^10.1.1",
    "playwright": "^1.55.0",
    "prettier": "^3.4.2",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.20.3",
    "turbo": "^2.3.3",
    "typedoc": "^0.25.3",
    "typedoc-plugin-markdown": "^3.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.35.1",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "pnpm": {
    "overrides": {
      "three": "0.176.0",
      "react": "19.1.0",
      "@react-three/fiber": "^9.1.2"
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.4.2",
    "@react-three/fiber": "^9.1.2",
    "three": "0.176.0",
    "zustand": "^5.0.6"
  }
}

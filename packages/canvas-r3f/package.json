    "@size-limit/preset-small-lib": "^11.1.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20.17.15",
    "@types/react": "^19.0.3",
    "@types/three": "0.176.0",
    "jsdom": "^26.0.0",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "size-limit": "^11.1.0",
    "three": "0.176.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@react-three/drei": ">=10.0.0",
    "@react-three/fiber": ">=8.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": ">=0.150.0"
  },

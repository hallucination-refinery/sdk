{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Refinery SDK Documentation",
  "entryPointStrategy": "packages",
  "entryPoints": ["packages/*/src/index.ts"],
  "out": "docs/reference",
  "exclude": ["**/__tests__/**"],
  "tsconfig": "tsconfig.json",
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "default",
  "readme": "./README.md",
  "includeVersion": true,
  "categorizeByGroup": true,
  "categoryOrder": ["Core", "Algorithms", "State", "UI", "Input", "Widgets", "*"],
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "gitRevision": "main",
  "hideGenerator": false
}
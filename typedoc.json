{
  "$schema": "https://typedoc.org/schema.json",
  "name": "Refinery SDK Documentation",
  "entryPointStrategy": "packages",
  "entryPoints": [
    "packages/schema",
    "packages/ops", 
    "packages/store",
    "packages/canvas-r3f",
    "packages/input-hub",
    "packages/widget-aperture",
    "packages/widget-hud"
  ],
  "out": "docs",
  "exclude": [
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/test-setup.ts",
    "**/dist/**"
  ],
  "plugin": ["typedoc-plugin-markdown"],
  "theme": "default",
  "readme": "./README.md",
  "includeVersion": true,
  "categorizeByGroup": true,
  "categoryOrder": ["Core", "Algorithms", "State", "UI", "Input", "Widgets", "*"],
  "navigation": {
    "includeCategories": true,
    "includeGroups": true
  },
  "gitRevision": "main",
  "hideGenerator": false
}
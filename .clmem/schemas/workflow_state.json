{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["workflow_version", "iteration", "mental_model"],
  "properties": {
    "workflow_version": { "type": "string", "pattern": "^\\d+\\.\\d+$" },
    "iteration": { "type": "integer", "minimum": 0 },
    "mental_model": {
      "type": "object",
      "properties": {
        "hypotheses": {
          "type": "object",
          "patternProperties": {
            "^H\\d+$": {
              "type": "object",
              "required": ["statement", "confidence", "evidence_count"],
              "properties": {
                "statement": { "type": "string" },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "evidence_count": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    },
    "checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
